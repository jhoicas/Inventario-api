APP_ENV=production
APP_NAME=invorya-erp

# Dominio público de la API (sin protocolo)
DOMAIN=api.ludoia.com

# Base de datos PostgreSQL (servicio 'db' del docker-compose)
DB_HOST=db
DB_PORT=5432
DB_USER=erp_user
DB_PASSWORD=erp_password_cambiar
DB_NAME=erp_db

# JWT
JWT_SECRET=CAMBIAR_POR_UN_SECRET_SEGURO
JWT_EXPIRATION_MINUTES=60
JWT_ISSUER=invorya-erp

# DIAN
DIAN_TECHNICAL_KEY=CLAVE_TECNICA_DIAN
DIAN_ENVIRONMENT=1
DIAN_ENV=prod
# Ruta del certificado dentro del contenedor (volumen ./certs montado en /app/certs)
DIAN_CERT_PATH=/app/certs/certificado_prueba.p12
DIAN_CERT_PASSWORD=CONTRASEÑA_DEL_CERTIFICADO

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-TU_CLAVE
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

